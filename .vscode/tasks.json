{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ADB: Silence MESA log",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/adb_silence_mesa.ps1"
      ],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Windows: Ensure Build Tools",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        ". '${workspaceFolder}/tools/windows_build_tools.ps1'; Ensure-WindowsBuildTools -IssPath '${workspaceFolder}/inno_setup_installer.iss' -InstallIfMissing $true"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "WebView2: Clear userDataFolder (label_manager)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/clear_webview2_userdata.ps1",
        "-AppId",
        "label_manager"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}